{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate.js": { "maxDuration": 60 },
    "api/checkout.js": { "maxDuration": 15 },
    "api/feedback.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ]
}
